<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Logowanie - AD Portal</title>
  <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light d-flex align-items-center vh-100">
  <main class="container">
    <section class="card mx-auto shadow-sm" style="max-width: 420px;">
      <div class="card-body">
        <h1 class="h4 mb-3">Portal AD - szpital</h1>
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <form method="post" action="/login">
          <div class="mb-3">
            <label class="form-label">Login</label>
            <input class="form-control" name="login" required />
          </div>
          <div class="mb-3">
            <label class="form-label">Hasło</label>
            <input class="form-control" type="password" name="password" required />
          </div>
          <button class="btn btn-primary w-100">Zaloguj</button>
        </form>
      </div>
    </section>
  </main>
</body>
</html>
