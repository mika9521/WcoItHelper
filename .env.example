PORT=3000
SESSION_SECRET=zmien-to-na-losowy-sekret
# Opcja 1: pełny URL LDAP/LDAPS (ma pierwszeństwo nad AD_PROTOCOL/AD_HOST/AD_PORT)
AD_URL=
# Opcja 2: składanie URL z pól poniżej
AD_PROTOCOL=ldaps
AD_HOST=dc01.hospital.local
AD_PORT=636
# Dla ldap:// możesz włączyć StartTLS (true/false)
AD_TLS_ENABLED=true
AD_BASE_DN=DC=hospital,DC=local
AD_BIND_DN=CN=svc_adportal,OU=Service,DC=hospital,DC=local
AD_BIND_PASSWORD=SuperSecretPassword
# false = wszystkie operacje AD na koncie serwisowym; true = operacje AD na koncie zalogowanego użytkownika
AD_USE_LOGGED_USER_BIND=false
AD_ALLOWED_GROUP_DN=CN=AD-Portal-Admins,OU=Groups,DC=hospital,DC=local
AD_ALLOWED_USERS=user1,user2
AD_TLS_REJECT_UNAUTHORIZED=true
AD_DEBUG=false
